# Credenciales de Supabase para el build de producción (opcional).
# Copiá este archivo a ".env.production.local" (ya está en .gitignore, nunca
# se sube a git) y completá con la URL y la clave "anon" de tu proyecto
# (Supabase → Project Settings → API Keys). Ver SUPABASE.md, Paso 7.
#
# Sin este archivo, la app funciona 100% local (como siempre) y el modo
# nube se activa manualmente desde Ajustes en cada navegador.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
